# =========================================================================
# SMTP Configuration for Website Assessment Scorecard
# Rename this file to '.env' (or '.env.local' for local development)
# and fill in the values below.
# =========================================================================

# 1. SMTP Server Host (e.g., smtp.gmail.com for Gmail, or mail.yourdomain.com for cPanel)
SMTP_HOST=smtp.gmail.com

# 2. SMTP Port (465 for secure SSL, 587 for TLS/STARTTLS)
SMTP_PORT=465

# 3. SMTP Authenticated Username (your full email address)
SMTP_USER=your-email@gmail.com

# 4. SMTP Authenticated Password (for Gmail, use a 16-character App Password)
# Learn how to create one: https://support.google.com/accounts/answer/185833
SMTP_PASS=your-app-password-here

# 5. Admin Email (where lead notifications and scorecards are sent)
SMTP_ADMIN_EMAIL=555jinson@gmail.com
